---
import '../styles/global.css';
import LoadingScreen from '../components/LoadingScreen.astro';

export interface Props {
	title: string;
	description?: string;
}

const { title, description = "Gehobene österreichische Küche – zart im Detail, voller Charakter." } = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet">

		<!-- Preload hero image -->
		<link rel="preload" as="image" href={`${import.meta.env.BASE_URL}images/restaurant-interior-3.webp`} fetchpriority="high">

		<!-- Store base URL for scripts -->
		<meta name="astro-base-url" content={import.meta.env.BASE_URL}>

		<title>{title}</title>
	</head>
	<body class="bg-ink text-text-high font-body antialiased">
		<LoadingScreen />
		<slot />
		<script>
			// Cache-bust PDF/DOCX links on every click
			document.addEventListener('click', (e) => {
				const link = (e.target as HTMLElement).closest('a[href]') as HTMLAnchorElement | null;
				if (!link) return;
				const href = link.getAttribute('href') || '';
				if (/\.(pdf|docx)$/i.test(href.split('?')[0])) {
					e.preventDefault();
					window.open(href.split('?')[0] + '?v=' + Date.now(), '_blank');
				}
			});
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}

	body {
		font-size: 17px;
		line-height: 1.6;
		overflow-x: hidden; /* Prevent horizontal scroll */
	}

	/* Prevent unwanted resize cursors */
	*, *::before, *::after {
		resize: none !important;
	}

	/* Ensure no invisible draggable elements */
	* {
		user-select: inherit;
		-webkit-user-drag: none;
	}

	/* Focus styles */
	*:focus-visible {
		outline: 2px solid #F0C9B6;
		outline-offset: 2px;
	}

	/* Smooth transitions */
	a, button {
		transition: all 0.2s ease-in-out;
	}

	/* Fix any potential sidebar-like elements - but exclude overlay divs */
	div:empty:not([class*="overlay"]):not([class*="hero"]) {
		display: none !important;
	}
</style>
