---
---

<section class="py-20 bg-surface-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <!-- Map -->
      <div class="order-2 lg:order-1">
        <div class="aspect-[4/3] border border-line-gold/20 overflow-hidden relative">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2687.123456789!2d16.234567!3d47.812345!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sLange%20Gasse%2020%2C%202700%20Wiener%20Neustadt!5e0!3m2!1sde!2sat!4v1234567890123"
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="grayscale hover:grayscale-0 transition-all duration-300"
            title="Mädchen & Wolf Restaurant Location"
          ></iframe>
          
          <!-- Overlay for better contrast -->
          <div class="absolute inset-0 bg-accent-rose/5 pointer-events-none"></div>
        </div>
      </div>
      
      <!-- Content -->
      <div class="order-1 lg:order-2">
        <h2 class="text-3xl font-heading font-semibold tracking-heading text-text-high mb-6">
          Anfahrt
        </h2>
        
        <div class="space-y-6">
          <!-- Address -->
          <div>
            <h3 class="text-lg font-medium text-text-high mb-2">Adresse</h3>
            <address class="text-text-mid not-italic leading-relaxed">
              Mädchen & Wolf<br>
              Lange Gasse 20<br>
              2700 Wiener Neustadt<br>
              Österreich
            </address>
          </div>
          
          <!-- Travel Info -->
          <div>
            <h3 class="text-lg font-medium text-text-high mb-3">Anreise</h3>
            <div class="space-y-3">
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-accent-rose mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.22.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/>
                </svg>
                <div>
                  <p class="text-text-high font-medium">PKW</p>
                  <p class="text-text-mid text-sm">Parkplätze in der Nähe verfügbar</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-accent-rose mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <div>
                  <p class="text-text-high font-medium">Öffentliche Verkehrsmittel</p>
                  <p class="text-text-mid text-sm">Gute Anbindung an Bus und Bahn</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Route Button -->
          <div class="pt-4">
            <a 
              href="https://maps.google.com/maps?q=Lange+Gasse+20,+2700+Wiener+Neustadt" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center px-6 py-3 bg-transparent border border-accent-rose text-accent-rose hover:bg-accent-rose hover:text-ink transition-all duration-200 focus:ring-2 focus:ring-accent-rose focus:ring-offset-2 focus:ring-offset-surface-1"
            >
              <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
              Route planen
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
