<section id="events" class="py-20 bg-surface-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-heading font-semibold tracking-heading text-text-high mb-4">Events</h2>
      <p class="text-text-mid max-w-2xl mx-auto">Dieser Bereich ist im Aufbau. Der Eventkalender bzw. ein Überblick wird hier als PDF gepflegt.</p>
    </div>

    <div class="max-w-3xl mx-auto bg-ink border border-line-gold/20 p-8 text-center">
      <p class="text-text-high mb-5">Aktuelle Eventübersicht als PDF</p>
      <a href={`${import.meta.env.BASE_URL}pdfs/Events-Ueberblick.pdf`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 border border-accent-rose text-accent-rose hover:bg-accent-rose hover:text-ink transition-all">Events PDF öffnen</a>
      <p class="text-xs text-text-mid mt-4">Inhalt wird nachträglich befüllt.</p>
    </div>
  </div>
</section>
